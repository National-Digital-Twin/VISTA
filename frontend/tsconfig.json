{
  "compilerOptions": {
    "baseUrl": "src",
    "paths": {
      "@/*": ["*"]
    },
    "plugins": [
      {
        "name": "typescript-plugin-css-modules",
        "options": {
          "classnameTransform": "camelCaseOnly",
          "goToDefinition": true
        }
      }
    ],
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "target": "ES2022",
    "moduleResolution": "bundler",
    "module": "ESNext",
    "skipLibCheck": true,
    "lib": ["esnext", "dom"]
  },
  "include": ["src"]
}
