{
    "name": "vista",
    "version": "0.90.0",
    "private": true,
    "homepage": "vista",
    "license": "Apache-2.0",
    "type": "module",
    "scripts": {
        "build": "vite build",
        "format": "prettier --write .",
        "format-changed": "prettier --write --cache .",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "start": "vite --port 3001",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui",
        "test:watch": "vitest"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all",
            "not safari < 10",
            "not chrome < 51",
            "not android < 5",
            "not ie < 12"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "overrides": {
        "diff": "4.0.4"
    },
    "dependencies": {
        "@emotion/react": "11.14.0",
        "@emotion/styled": "11.14.1",
