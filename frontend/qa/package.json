{
  "name": "ndtp-qa-test-automation",
  "version": "1.0.0",
  "description": "test automation for the National Digital Twin Project",
  "main": "index.js",
  "scripts": {
    "debug": "cross-env ENV=prod PWDEBUG=1 DEBUG=pw:api cucumber-js --config=config/cucumber.js",
    "pretest": "npx ts-node src/helper/report/init.ts",
    "test": "cross-env ENV=dev FORCE_COLOR=0 cucumber-js --config=config/cucumber.js || true",
    "posttest": "npx ts-node src/helper/report/report.ts",
    "test:failed": "cucumber-js -p rerun @rerun.txt"
  },
  "keywords": [
    "cucumber",
    "cucumber - TS",
    "playwright-cucumber"
  ],
  "author": "NDTP",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "^11.3.0",
    "@playwright/test": "1.53.2",
    "cross-env": "^7.0.3",
    "dotenv": "^17.0.1",
    "fs-extra": "^11.3.0",
    "lighthouse": "^12.7.1",
    "multiple-cucumber-html-reporter": "^3.9.3",
    "playwright-lighthouse": "^4.0.0",
    "ts-node": "^10.9.2",
    "winston": "^3.17.0"
  }
}
