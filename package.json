    "cytoscape-node-html-label": "^1.2.2",
    "lodash": "^4.17.21",
    "mapbox-gl-draw-geodesic": "^2.1.3",
    "maplibre-gl": "^2.4.0",
    "primeicons": "^6.0.1",
    "primereact": "^9.2.1",
    "re-resizable": "^6.9.9",
    "react": "^17.0.2",
    "react-checkbox-tree": "^1.8.0",
    "react-cytoscapejs": "^1.2.1",
    "react-dom": "^17.0.2",
    "react-error-boundary": "^3.1.4",
    "react-map-gl": "^7.0.15",
    "react-modal": "^3.16.1",
    "react-query": "^3.39.3",
    "react-query-devtools": "^2.6.3",
