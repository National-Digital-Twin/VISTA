    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "chmod +x ./env.sh && ./env.sh && cp env-config.js ./public/ && PORT=3001 craco start",
    "build": "craco build",
    "build:tailwind": "npx tailwindcss -i ./src/index.css -o ./src/main.css",
    "babel": "babel --plugins @babel/plugin-transform-arrow-functions script.js",
    "test": "craco test",
    "test:ci": "craco test --ci --json --outputFile=\"reports/results.json\" --watchAll=false",
    "eject": "react-scripts eject",
    "prepare": "husky install"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-transform-modules-commonjs": "^7.19.6",
    "@commitlint/cli": "^17.1.2",
    "@commitlint/config-conventional": "^17.1.0",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "12.1.5",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/user-event": "^14.4.3",
    "commitizen": "^4.2.5",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^8.0.0",
    "jest-canvas-mock": "^2.4.0",
    "jest-fetch-mock": "^3.0.3",
    "jest-image-snapshot": "^4.5.1",
    "msw": "^0.47.4",
    "puppeteer": "^14.1.1",
    "react-app-rewired": "^2.2.1",
    "release-please": "^14.6.0",
    "tailwindcss": "^3.1.8"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "jest": {
    "transformIgnorePatterns": [
      "node_modules/(?!mapbox-gl-draw-geodesic)/"
    ]
  }
}
